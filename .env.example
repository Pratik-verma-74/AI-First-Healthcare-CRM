# Supabase PostgreSQL Configuration
# Format for SQLAlchemy async/sync connection:
# postgresql+psycopg2://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres
DATABASE_URL=postgresql+psycopg2://postgres:your_password@db.your_project_id.supabase.co:5432/postgres
SUPABASE_URL=https://your_project_id.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Groq API Configuration for LangGraph AI Engine (gemma2-9b-it)
GROQ_API_KEY=your_groq_api_key_here

# Backend Server Configuration
PORT=8000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
